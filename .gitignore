# Dependencies
node_modules/

# OS artefacts
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local

# Build output (none currently, but reserve)
dist/
build/

# Generated test results (written by server at runtime)
results/*.csv
results/.ready

# Python virtualenv (used by presentation tooling)
documents/presentation/venv/
**/__pycache__/

# Research papers / reference material — kept locally, not redistributed
documents/references/

# Intermediate deck rebuilds — milestone PDFs are added explicitly via
# `git add -f "documents/presentation/N-DHT Presentation v0.X.Y.pdf"`.
# This keeps session rebuilds out of the working-tree status without
# affecting any PDFs that are already tracked.
documents/presentation/N-DHT Presentation v*.pdf

# Stray reference PDFs in the slide-images folder (place under documents/references/)
documents/presentation/images/*.pdf

# LaTeX / Tectonic build artifacts in the paper directory
documents/paper/*.aux
documents/paper/*.log
documents/paper/*.blg
documents/paper/*.bbl
documents/paper/*.out
documents/paper/*.toc
